PORT=5000

# Option 1 (recommended): separate Atlas credentials
MONGO_USER=your_db_user
MONGO_PASSWORD=your_db_password
MONGO_CLUSTER=cluster0.xxxxx.mongodb.net
MONGO_DB_NAME=smart-flashcards

# Optional fallback for Windows SSL/SRV issues (copy from Atlas -> Connect -> Drivers)
# MONGO_URI_STANDARD=mongodb://user:pass@host1:27017,host2:27017,host3:27017/smart-flashcards?ssl=true&replicaSet=atlas-xxxxx-shard-0&authSource=admin

# Option 2: full connection string
# MONGO_URI=mongodb+srv://your_db_user:your_db_password@cluster0.xxxxx.mongodb.net/smart-flashcards?retryWrites=true&w=majority&authSource=admin

JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d
NLP_SERVICE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

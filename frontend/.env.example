# Environment Variables Configuration
# For local development: Point to localhost backend on port 5000
# For production: Point to Render backend URL
# 
# Development setup:
#   cp .env.example .env.local
#   npm run dev
#
# Production (Vercel):
#   Set VITE_API_URL in Vercel dashboard to your Render backend URL
#   Format: https://your-service-name.onrender.com/api

VITE_API_URL=http://localhost:5000/api
